# =============================================================
# Mapbox (frontend) — embarcado em build-time via build args
# =============================================================
NEXT_PUBLIC_MAPBOX_TOKEN=pk.your_mapbox_public_token_here
NEXT_PUBLIC_API_URL=

# =============================================================
# GLPI MySQL/MariaDB (Next.js Route Handlers)
# Em arquivos lidos pelo docker compose, use ASPAS SIMPLES
# se a senha tiver '$' (compose interpola $VAR mesmo no env_file).
# =============================================================
GLPI_DB_HOST=127.0.0.1
GLPI_DB_PORT=3306
GLPI_DB_USER=glpi
GLPI_DB_PASSWORD='trocar-senha'
GLPI_DB_NAME=glpi
GLPI_DB_POOL_LIMIT=8

# Pasta de uploads (volume do plugin VistoMap-Projetos)
GLPI_UPLOAD_PATH=/var/www/html/glpi/plugins/vistomapprojetos/uploads
GLPI_AUX_TABLE=glpi_plugin_vistomap_projects

# =============================================================
# PostgreSQL/PostGIS — source-of-truth dos postes
# Lido pelo serviço `postgis` e `postes-api` no compose.
# =============================================================
PG_USER=vistomap
PG_PASSWORD='trocar-senha-pg'
PG_DATABASE=vistomap

# =============================================================
# Fastify (postes-api)
# =============================================================
# Segredo compartilhado com o Next pra validar JWT da sessão.
# Gere com: openssl rand -hex 64
JWT_SECRET=trocar-por-um-hex-de-64-bytes

# Raio máximo (m) para mudança de poste ser aceita.
POSTE_TROCA_RAIO_M=50

# CORS — em produção atrás de proxy reverso, deixe '*' (mesma origem).
CORS_ORIGIN=*
