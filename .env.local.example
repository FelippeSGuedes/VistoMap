# Mapbox (frontend)
NEXT_PUBLIC_MAPBOX_TOKEN=pk.your_mapbox_public_token_here
NEXT_PUBLIC_API_URL=

# GLPI MySQL/MariaDB
GLPI_DB_HOST=127.0.0.1
GLPI_DB_PORT=3306
GLPI_DB_USER=glpi
GLPI_DB_PASSWORD=glpi
GLPI_DB_NAME=glpi
GLPI_DB_POOL_LIMIT=8

# Caminho absoluto onde o plugin VistoMap-Projetos espera os uploads
# Dev (Windows): C:\Users\<user>\VistoMap\uploads-dev
# Prod (Linux):  /var/www/html/glpi/plugins/vistomapprojetos/uploads
GLPI_UPLOAD_PATH=/var/www/html/glpi/plugins/vistomapprojetos/uploads

# Tabela auxiliar do plugin VistoMap-Projetos
GLPI_AUX_TABLE=glpi_plugin_vistomap_projects
