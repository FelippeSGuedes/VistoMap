{
  "name": "vistomap-postes-api",
  "version": "0.1.0",
  "private": true,
  "description": "API geoespacial (Fastify + Postgres/PostGIS) do VistoMap. Source-of-truth dos postes.",
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "build": "tsc -p tsconfig.json",
    "start": "node dist/server.js",
    "migrate:make": "knex --knexfile knexfile.ts migrate:make",
    "migrate:latest": "knex --knexfile knexfile.ts migrate:latest",
    "migrate:rollback": "knex --knexfile knexfile.ts migrate:rollback",
    "import:csv:dev": "tsx src/scripts/import-csv.ts",
    "import:csv": "node dist/scripts/import-csv.js"
  },
  "dependencies": {
    "@fastify/cors": "^9.0.1",
    "@fastify/helmet": "^11.1.1",
    "@fastify/jwt": "^8.0.1",
    "@fastify/rate-limit": "^9.1.0",
    "@fastify/sensible": "^5.6.0",
    "csv-parse": "^5.5.6",
    "fastify": "^4.28.1",
    "knex": "^3.1.0",
    "pg": "^8.13.0",
    "pg-copy-streams": "^6.0.6",
    "pino-pretty": "^11.2.2",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/node": "^20.16.5",
    "@types/pg": "^8.11.10",
    "@types/pg-copy-streams": "^1.2.5",
    "tsx": "^4.19.1",
    "typescript": "^5.6.2"
  },
  "engines": {
    "node": ">=20"
  }
}
